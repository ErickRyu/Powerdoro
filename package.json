{
  "name": "powerdoro",
  "version": "1.0.0",
  "description": "Pomodoro timer with mandatory retrospective logging",
  "main": "dist/main/main.js",
  "build": {
    "appId": "com.electron.powerdoro",
    "productName": "Powerdoro",
    "files": [
      "dist/**/*",
      "view/**/*",
      "res/**/*",
      "tray-window-renderer.js",
      "block-window-renderer.js",
      "settings-window-renderer.js",
      "stats-window-renderer.js",
      "node_modules/chart.js/dist/chart.umd.js"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "notarize": false
    },
    "mas": {
      "category": "public.app-category.productivity",
      "type": "distribution",
      "target": [
        {
          "target": "mas",
          "arch": [
            "universal"
          ]
        }
      ],
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile",
      "artifactName": "${productName}-${version}-mas.${ext}",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "masDev": {
      "category": "public.app-category.productivity",
      "type": "development",
      "target": [
        {
          "target": "mas-dev",
          "arch": [
            "universal"
          ]
        }
      ],
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "afterSign": "scripts/notarize.js"
  },
  "scripts": {
    "build": "tsc",
    "rebuild:electron": "npx electron-rebuild -f -w better-sqlite3",
    "rebuild:mas": "npx electron-rebuild -f -w better-sqlite3 --arch=universal",
    "start": "npm run rebuild:electron && npm run build && electron .",
    "test": "jest",
    "pack": "npm run rebuild:electron && npm run build && electron-builder --dir",
    "dist": "npm run rebuild:electron && npm run build && electron-builder",
    "dist:dmg": "npm run rebuild:electron && npm run build && electron-builder --mac dmg",
    "dist:mas": "npm run rebuild:mas && npm run build && electron-builder --mac mas",
    "dist:mas-dev": "npm run rebuild:mas && npm run build && electron-builder --mac mas-dev"
  },
  "repository": "",
  "keywords": [
    "Electron",
    "pomodoro",
    "timer",
    "productivity",
    "retrospective"
  ],
  "author": "rkggmdii@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "electron-store": "^8.2.0",
    "electron-traywindow-positioner": "^1.1.1"
  }
}
